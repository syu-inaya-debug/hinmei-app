{
  "version": 2,
  "builds": [
    {
      "src": "hinmei_web/api/process.py",
      "use": "@vercel/python"
    },
    {
      "src": "hinmei_web/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/process",
      "dest": "/hinmei_web/api/process.py"
    },
    {
      "src": "/(.*)",
      "dest": "/hinmei_web/public/$1"
    }
  ]
}
